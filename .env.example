# Supabase
# Create a project at https://supabase.com, then run supabase/schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob (for storing uploaded screenshots / PDF invoices)
# Create a Blob store in your Vercel project dashboard and copy the token.
BLOB_READ_WRITE_TOKEN=

# Feature flags
# When Supabase env vars are absent, the app falls back to in-memory mock/seed
# data so the frontend is fully explorable without any backend configured.
NEXT_PUBLIC_USE_MOCK_DATA=true
